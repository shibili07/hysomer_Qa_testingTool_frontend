# Copy to .env and adjust. See https://vite.dev/guide/env-and-mode.html

# QA console API (Express backend). Used in the browser at build time; set this on CI / Render to your deployed API URL.
# No trailing slash.
VITE_API_URL=http://localhost:5000

# Dev-only: default organization id for the Vite dev/preview proxy (/api/external-invoices).
# Not prefixed with VITE_ — not exposed to client bundles.
HYSOMER_ORGANIZATION_ID=
